ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=generate-a-long-random-string
CRON_SECRET=generate-another-long-random-string

# Vercel Blob is used automatically on Vercel when this token exists.
BLOB_READ_WRITE_TOKEN=

# Required for importing owner-visible/unlisted channel uploads.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Optional. If omitted, the app looks up your uploads playlist from the OAuth account.
YOUTUBE_UPLOADS_PLAYLIST_ID=
